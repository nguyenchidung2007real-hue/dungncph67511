# Phân tích seasonality theo tháng
df3['month'] = df3.index.month
monthly_avg = df3.groupby('month')['close_price'].mean()
month_labels = ['T1','T2','T3','T4','T5','T6','T7','T8','T9','T10','T11','T12']

fig7, axes7 = plt.subplots(1, 2, figsize=(16, 6))

axes7[0].bar(month_labels[:len(monthly_avg)], monthly_avg.values,
             color='teal', alpha=0.85, edgecolor='white')
axes7[0].set_title('Giá Đóng Cửa Trung Bình Theo Tháng', fontsize=13, fontweight='bold')
axes7[0].set_xlabel('Tháng')
axes7[0].set_ylabel('Giá TB (USD)')

# Boxplot theo tháng để tìm pattern lặp lại
monthly_data = [df3[df3['month'] == m]['close_price'].values for m in range(1, 13)]
bp = axes7[1].boxplot(monthly_data, labels=month_labels, patch_artist=True,
