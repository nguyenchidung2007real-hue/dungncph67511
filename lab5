print("\n[4.3-4.4] Đã lưu biểu đồ: bai4_trend_seasonality_quy.png")

# Decomposition đầy đủ bằng statsmodels
decomp4 = seasonal_decompose(df4['production'], model='additive', period=52)

fig9, axes9 = plt.subplots(4, 1, figsize=(14, 14))
plot_data = [
    (decomp4.observed, 'Observed (Sản lượng gốc)',     'steelblue'),
    (decomp4.trend,    'Trend (Xu hướng dài hạn)',     'orange'),
    (decomp4.seasonal, 'Seasonality (Mùa vụ hàng năm)','green'),
    (decomp4.resid,    'Residual (Phần dư)',             'red'),
]
for ax, (data, title, color) in zip(axes9, plot_data):
    ax.plot(data, color=color, linewidth=1.2)
    ax.set_title(title, fontsize=12, fontweight='bold')
    ax.set_ylabel('Giá trị')
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%m/%Y'))
