# Rolling Mean Trend
axes6[1].plot(df3.index, df3['close_price'],
              color='#90CAF9', linewidth=0.8, alpha=0.5, label='Giá đóng cửa')
axes6[1].plot(df3.index, df3['rolling_7'],
              color='orange', linewidth=1.8, label='Rolling Mean 7 ngày')
axes6[1].plot(df3.index, df3['rolling_30'],
              color='red',    linewidth=2.2, label='Rolling Mean 30 ngày (Trend)')
axes6[1].set_title('Nhận Diện Xu Hướng Bằng Rolling Mean', fontsize=14, fontweight='bold')
