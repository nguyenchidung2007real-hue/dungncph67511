df4 = pd.read_csv('ITA105_Lab_5_Production.csv')

# Chuyển week_start về datetime
df4['week_start'] = pd.to_datetime(df4['week_start'])
df4.set_index('week_start', inplace=True)
print("\n[4.1] Dữ liệu gốc:")
print(df4.head())
print(f"Shape: {df4.shape}")

# Kiểm tra và điền missing values
print(f"\nSố missing: {df4.isnull().sum().values[0]}")
df4 = df4.asfreq('W-SUN')
print(f"Số NaN sau asfreq: {df4.isnull().sum().values[0]}")
df4['production'] = df4['production'].interpolate(method='linear')
print(f"Số NaN sau interpolation: {df4.isnull().sum().values[0]}")

# Tạo đặc trưng: tuần, quý, năm
df4['week']    = df4.index.isocalendar().week.astype(int)
df4['quarter'] = df4.index.quarter
df4['year']    = df4.index.year
print("\n[4.2] Đặc trưng thời gian:")
print(df4.head())

# Phát hiện trend bằng rolling mean
df4['rolling_4']  = df4['production'].rolling(window=4,  center=True).mean()
df4['rolling_13'] = df4['production'].rolling(window=13, center=True).mean()   # ~1 quý

fig8, axes8 = plt.subplots(2, 1, figsize=(14, 10))

axes8[0].plot(df4.index, df4['production'],
              color='gray', linewidth=0.8, alpha=0.6, label='Sản xuất gốc')
axes8[0].plot(df4.index, df4['rolling_4'],
              color='orange', linewidth=1.8, label='Rolling 4 tuần')
axes8[0].plot(df4.index, df4['rolling_13'],
              color='blue',   linewidth=2.2, label='Rolling 13 tuần (~1 quý, Trend)')
axes8[0].set_title('Xu Hướng Sản Xuất Dài Hạn (Rolling Mean)', fontsize=14, fontweight='bold')
axes8[0].set_xlabel('Tuần')
axes8[0].set_ylabel('Sản lượng')
axes8[0].legend()
axes8[0].xaxis.set_major_formatter(mdates.DateFormatter('%m/%Y'))

# Phân tích seasonality theo quý
quarterly_avg = df4.groupby('quarter')['production'].mean()
quarter_labels = ['Q1', 'Q2', 'Q3', 'Q4']

axes8[1].bar(quarter_labels, quarterly_avg.values,
             color=['#42A5F5', '#66BB6A', '#FFA726', '#EF5350'],
             alpha=0.85, edgecolor='white')
for i, v in enumerate(quarterly_avg.values):
    axes8[1].text(i, v + 5, f"{v:.0f}", ha='center', fontweight='bold')
axes8[1].set_title('Sản Lượng Trung Bình Theo Quý (Seasonality)', fontsize=14, fontweight='bold')
axes8[1].set_xlabel('Quý')
axes8[1].set_ylabel('Sản lượng TB')

plt.tight_layout()
plt.savefig('bai4_trend_seasonality_quy.png', dpi=150, bbox_inches='tight')
